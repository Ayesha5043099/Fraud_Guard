   "source": [
    "-- Check 3: Duplicate transactions to nahi (same account, amount, step)\n",
    "SELECT nameOrig, nameDest, amount, step, COUNT(*) AS dup_count\n",
    "FROM workspace.default.feature_transactions\n",
    "GROUP BY nameOrig, nameDest, amount, step\n",
    "HAVING COUNT(*) > 1\n",
    "LIMIT 20;"
   ]
  }
